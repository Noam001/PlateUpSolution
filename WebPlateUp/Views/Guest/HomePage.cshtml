@using Models;
@model HomePageViewModel
@{
    ViewData["Title"] = "HomePage";
    Layout = "~/Views/Shared/MasterPage.cshtml";
}
@if (!ViewData.ModelState.IsValid)
{
    <script>
        window.onload = function() {
            const reviewSection = document.getElementById('reviews-section');
            if (reviewSection) {
                reviewSection.scrollIntoView({ behavior: 'smooth' });
            }
        };
    </script>
}

<link href="~/stylesheet/homepage.css" rel="stylesheet" />
<main class="main">
    <div class="main-section">
        <div class="main-Title">
            <h1 class="PlateUp">PlateUp</h1>
            <p class="description">Fresh flavors, warm ambiance, and every dish <br>crafted with passion — welcome to a dining <br>experience worth savoring.</p>
            <a href="#reviews-section" class="view-reviews-btn">View Reviews ▼</a>
        </div>
        <div class="main-image">
            <img src="~/images/pastadish.png" class="dish-img" />
        </div>
    </div>
    <div class="ReviewBlock" id="reviews-section">
        <div class="reviews-container">
            <!-- צד שמאל - רשימת ביקורות -->
            <div class="reviews-left">
                <h2 class="Reviews">Reviews</h2>
                <div class="allReviews">
                    @{
                        string currentClientId = Context.Session.GetString("clientId");
                        List<Review> sortedReviews = Model.Reviews
                        .OrderByDescending(review => review.ClientId.ToString() == currentClientId)
                        .ToList();
                    }
                    @foreach (Review review in sortedReviews)
                    {
                        bool isMyReview = review.ClientId.ToString() == currentClientId;
                        <div class="review-card">
                            <div class="review-stars">
                                @for (int i = 0; i < review.ReviewRating; i++)
                                {
                                    <span>★</span>
                                }
                                @for (int i = review.ReviewRating; i < 5; i++)
                                {
                                    <span style="color:#ccc;">★</span>
                                }
                            </div>
                            @if (isMyReview)
                            {
                                <form asp-controller="Client" asp-action="DeleteReview" method="get" style="display:inline;">
                                    <input type="hidden" name="reviewId" value="@review.ReviewId" />
                                    <button type="submit" class="delete-btn" onclick="return confirm('Are you sure?')">🗑️</button>
                                </form>
                            }
                            <p class="review-text">@review.ReviewComment</p>
                            <div class="review-footer">
                                <span class="review-client">@review.ClientId</span>
                                <span class="review-date">@review.ReviewDate</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- צד ימין - טופס -->
            <div class="reviews-right">
                <h2 class="Reviews">Write a Review</h2>
                <form asp-controller="Client" asp-action="LeaveAReview" class="reviewBox" method="post">
                    <input asp-for="Review.ClientId" type="hidden" value="@ViewBag.ClientId" />
                    <input asp-for="Review.ReviewDate" type="hidden" value="@ViewBag.ReviewDate" />
                    <div class="rating-selector">
                        <div class="stars-input">
                            <input asp-for="Review.ReviewRating" type="radio" id="star5" value="5">
                            <label for="star5">★</label>
                            <input asp-for="Review.ReviewRating" type="radio" id="star4" value="4">
                            <label for="star4">★</label>
                            <input asp-for="Review.ReviewRating" type="radio" id="star3" value="3">
                            <label for="star3">★</label>
                            <input asp-for="Review.ReviewRating" type="radio" id="star2" value="2">
                            <label for="star2">★</label>
                            <input asp-for="Review.ReviewRating" type="radio" id="star1" value="1">
                            <label for="star1">★</label>
                        </div>
                    </div>
                    <textarea asp-for="Review.ReviewComment" placeholder="Write a Review..." class="reviewInput" rows="5"></textarea>
                    <div class="validation-errors">
                        <span asp-validation-for="Review.ReviewRating" class="errorData"></span>
                        <span asp-validation-for="Review.ReviewComment" class="errorData"></span>
                        <span asp-validation-for="Review.ClientId" class="errorData"></span>
                        <span asp-validation-for="Review.ReviewDate" class="errorData"></span>
                    </div>
                    <button class="Send" type="submit">Send</button>
                </form>
            </div>
        </div>
    </div>
</main>
