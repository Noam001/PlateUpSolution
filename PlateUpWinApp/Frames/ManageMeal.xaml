<Window x:Class="PlateUpWpf.Frames.ManageMeal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PlateUpWpf.Frames"
             mc:Ignorable="d" ResizeMode="NoResize"
             Height="570" Width="930" Background="#151233">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="booleanToVisibilityConverter"></BooleanToVisibilityConverter>
        <local:SelectedIndexToVisibility x:Key="selectedTovisibility"></local:SelectedIndexToVisibility>
    </Window.Resources>
    <Canvas>

        <!-- TITLE -->
        <TextBlock x:Name="PageTitle"
                   Text="Add Meal"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="#E0E1F1"
                   Canvas.Left="398"
                   Canvas.Top="38"/>

        <!-- MAIN CARD -->
        <Border Width="838"
                Height="420"
                Background="#1C1448"
                BorderBrush="#9497CD"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Canvas.Left="40"
                Canvas.Top="80" HorizontalAlignment="Left" VerticalAlignment="Center">

            <Canvas>

                <!-- IMAGE (LEFT SIDE) -->
                <Border Width="320"
                        Height="290"
                        Background="#3A2F6F"
                        BorderBrush="#9497CD"
                        BorderThickness="1"
                        CornerRadius="12"
                        Canvas.Left="20"
                        Canvas.Top="40">

                    <Grid>
                        <TextBox x:Name="MealPhotoEdit"
                                 Text="{Binding Meal.MealPhoto, Mode=TwoWay, 
                                               UpdateSourceTrigger=PropertyChanged,
                                               ValidatesOnDataErrors=True}"
                                 Visibility="Hidden"
                                 />
                        <Image x:Name="AddImage"/>
                        <Button x:Name="btnEditImage"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="btnEditImage_Click">
                            <StackPanel x:Name="ImageClickDesign" VerticalAlignment="Center">
                                <TextBlock Text="🖼️"
                                           FontSize="50"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Edit Image"
                                           FontSize="14"
                                           Foreground="#ADACD2"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=MealPhotoEdit}"
                           Visibility="{Binding (Validation.HasError), Converter={StaticResource booleanToVisibilityConverter},ElementName=MealPhotoEdit}"
                           Foreground="red"
                           FontSize="13"
                           Width="290"
                           Canvas.Left="26"
                           Canvas.Top="336"/>

                <!-- RIGHT SIDE CONTENT -->

                <!-- Meal Name -->
                <TextBlock Text="Meal Name"
                           Foreground="#ADACD2"
                           FontSize="13"
                           Canvas.Left="380"
                           Canvas.Top="30"/>
                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=txtEditItemName}"
                           Visibility="{Binding (Validation.HasError), Converter={StaticResource booleanToVisibilityConverter},ElementName=txtEditItemName}"
                           Foreground="red"
                           FontSize="13"
                           Width="290"
                           Canvas.Left="460"
                           Canvas.Top="30"/>

                <Border Width="350"
                        Height="45"
                        Background="#3A2F6F"
                        BorderBrush="#9497CD"
                        BorderThickness="1"
                        CornerRadius="8"
                        Canvas.Left="380"
                        Canvas.Top="50">
                    <TextBox x:Name="txtEditItemName"
                             Validation.ErrorTemplate="{x:Null}" 
                             Text="{Binding Meal.MealName, Mode=TwoWay, 
                                           UpdateSourceTrigger=PropertyChanged,
                                           ValidatesOnDataErrors=True}"
                             Background="Transparent"
                             Foreground="#E0E1F1"
                             BorderThickness="0"
                             FontSize="18"
                             Padding="10"
                             />
                </Border>

                <!-- Description -->
                <TextBlock Text="Description"
                           Foreground="#ADACD2"
                           FontSize="13"
                           Canvas.Left="380"
                           Canvas.Top="110"/>
                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=txtEditDescription}"
                           Visibility="{Binding (Validation.HasError), Converter={StaticResource booleanToVisibilityConverter},ElementName=txtEditDescription}"
                           Foreground="red"
                           FontSize="13"
                           Width="290"
                           Canvas.Left="460"
                           Canvas.Top="110"/>

                <Border Width="350"
                        Height="90"
                        Background="#3A2F6F"
                        BorderBrush="#9497CD"
                        BorderThickness="1"
                        CornerRadius="8"
                        Canvas.Left="380"
                        Canvas.Top="130">
                    <TextBox x:Name="txtEditDescription"
                             Validation.ErrorTemplate="{x:Null}" 
                             Text="{Binding Meal.MealDescription, Mode=TwoWay, 
                                      UpdateSourceTrigger=PropertyChanged,
                                      ValidatesOnDataErrors=True}"
                             Background="Transparent"
                             Foreground="#E0E1F1"
                             BorderThickness="0"
                             FontSize="13"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"/>
                </Border>

                <!-- Price -->
                <TextBlock Text="Price"
                           Foreground="#ADACD2"
                           FontSize="13"
                           Canvas.Left="380"
                           Canvas.Top="235"/>

                <Border Width="110"
                        Height="40"
                        Background="#3A2F6F"
                        BorderBrush="#9497CD"
                        BorderThickness="1"
                        CornerRadius="8"
                        Canvas.Left="380"
                        Canvas.Top="255">

                    <TextBox x:Name="txtEditPrice"
                             Validation.ErrorTemplate="{x:Null}" 
                             Text="{Binding Meal.MealPrice, Mode=TwoWay, 
                                     UpdateSourceTrigger=PropertyChanged,
                                     ValidatesOnDataErrors=True,
                                     ValidatesOnExceptions=True,
                                     NotifyOnValidationError=True}"
                             Background="Transparent"
                             Foreground="#E0E1F1"
                             BorderThickness="0"
                             Padding="10"/>
                </Border>
                <Image Source="/images/ErrorIcon.png"
                       Canvas.Left="458" Canvas.Top="262" Height="27" Width="27" 
                       HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Image.Visibility>
                        <Binding Path="(Validation.HasError)"
                                 ElementName="txtEditPrice"
                                 Converter="{StaticResource booleanToVisibilityConverter}"/>
                    </Image.Visibility>
                    <Image.ToolTip>
                        <Binding Path="(Validation.Errors)[0].ErrorContent" 
                                 ElementName="txtEditPrice"/>
                    </Image.ToolTip>
                </Image>


                <!-- Food Type -->
                <TextBlock Text="Food Type"
                           Foreground="#ADACD2"
                           FontSize="13"
                           Canvas.Left="510"
                           Canvas.Top="235"/>


                <ComboBox x:Name="cmbFoodTypes"                        
                          Width="130" Padding="12"
                          Height="40"
                          Canvas.Left="510"
                          Canvas.Top="255"
                          Background="#3A2F6F"
                          BorderBrush="#9497CD"
                          Foreground="Black"
                          DisplayMemberPath="FoodTypeName"
                          SelectedValuePath="FoodTypeId"/>
                <!-- Error Msg For FoodType -->
                <Border Width="135"
                     Height="40"
                     Canvas.Left="510"
                     Canvas.Top="302">

                    <Border.Visibility>
                        <Binding Path="(Validation.HasError)"
                                     ElementName="FoodTypeSelect"
                                     Converter="{StaticResource booleanToVisibilityConverter}"/>
                    </Border.Visibility>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Hidden">

                        <TextBlock Text="You must select a food type"
                                   Foreground="Red"
                                   FontSize="12"
                                   Canvas.Left="510"
                                   Canvas.Top="300"
                                   Visibility="{Binding SelectedIndex, ElementName=cmbFoodTypes, Converter={StaticResource selectedTovisibility}}" />
                    </ScrollViewer>

                </Border>

                <!-- Status -->
                <TextBlock Text="Status"
                           Foreground="#ADACD2"
                           FontSize="13"
                           Canvas.Left="660"
                           Canvas.Top="235"/>

                <ComboBox x:Name="cmbEditStatus"
                          Width="130" Padding="12"
                          Height="40"
                          Canvas.Left="660"
                          Canvas.Top="255"
                          Background="#3A2F6F"
                          BorderBrush="#9497CD"
                          Foreground="Black"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Available" Tag="True"/>
                    <ComboBoxItem Content="Unavailable" Tag="False"/>
                </ComboBox>

                <!-- BUTTONS -->
                <Button x:Name="btnDelete"
                        Content="Delete"
                        Width="110"
                        Height="40"
                        Background="#FF6B9D"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Canvas.Left="550"
                        Canvas.Top="340">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="#FF6B9D"
                                    CornerRadius="12">
                                <!-- כאן אתה שולט על העיגול -->

                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>
                                <!-- Hover Effect -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border"
                                            Property="Background"
                                            Value="#F06292"/>
                                </Trigger>

                                <!-- Press Effect -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border"
                                            Property="Opacity"
                                            Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="sumbitBtn"
                        Content="Add"
                        Width="110"
                        Height="40"
                        Background="#4FC3F7"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Canvas.Left="680"
                        Canvas.Top="340">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="#FF6B9D"
                                    CornerRadius="12">
                                <!-- כאן שולט על העיגול -->
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>
                                <!-- Hover Effect -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border"
                                            Property="Background"
                                            Value="#F06292"/>
                                </Trigger>

                                <!-- Press Effect -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border"
                                            Property="Opacity"
                                            Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Canvas>
        </Border>

    </Canvas>
</Window>
