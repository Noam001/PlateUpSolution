<Window x:Class="PlateUpWpf.Frames.ViewOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlateUpWpf.Frames"
        mc:Ignorable="d" ResizeMode="NoResize"
        Height="640" Width="930" Background="#151233">
    <Window.Resources>
        <local:ImageUrlToBitmapConverter x:Key="ImageConverter"/>
    </Window.Resources>
    <Canvas>

        <!-- TITLE -->
        <TextBlock Text="Order Details"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="#E0E1F1"
                   Canvas.Left="380"
                   Canvas.Top="25"/>

        <!-- MAIN CARD -->
        <Border Width="851"
                Height="500"
                Background="#1C1448"
                BorderBrush="#9497CD"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Canvas.Left="40"
                Canvas.Top="80">
            <Canvas>

                <!-- Order ID -->
                <TextBlock Text="Order ID"
                           Foreground="#ADACD2" FontSize="13"
                           Canvas.Left="40" Canvas.Top="30"/>
                <Border Width="160" Height="45" Background="#3A2F6F"
                        BorderBrush="#9497CD" BorderThickness="1"
                        CornerRadius="8" Canvas.Left="40" Canvas.Top="50">
                    <TextBlock x:Name="txtOrderId"
                               Foreground="#E0E1F1" FontSize="18"
                               FontWeight="Bold" Padding="10"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Client ID -->
                <TextBlock Text="Client ID"
                           Foreground="#ADACD2" FontSize="13"
                           Canvas.Left="230" Canvas.Top="30"/>
                <Border Width="200" Height="45" Background="#3A2F6F"
                        BorderBrush="#9497CD" BorderThickness="1"
                        CornerRadius="8" Canvas.Left="230" Canvas.Top="50">
                    <TextBlock x:Name="txtClientId"
                               Foreground="#E0E1F1" FontSize="18"
                               Padding="10" VerticalAlignment="Center"/>
                </Border>

                <!-- Status -->
                <TextBlock Text="Status"
                           Foreground="#ADACD2" FontSize="13"
                           Canvas.Left="460" Canvas.Top="30"/>
                <Border Width="150" Height="45" Background="#3A2F6F"
                        BorderBrush="#9497CD" BorderThickness="1"
                        CornerRadius="8" Canvas.Left="460" Canvas.Top="50">
                    <TextBlock x:Name="txtStatus"
                               Foreground="#E0E1F1" FontSize="16"
                               Padding="10" VerticalAlignment="Center"/>
                </Border>

                <!-- Order Date -->
                <TextBlock Text="Order Date"
                           Foreground="#ADACD2" FontSize="13"
                           Canvas.Left="40" Canvas.Top="130"/>
                <Border Width="200" Height="45" Background="#3A2F6F"
                        BorderBrush="#9497CD" BorderThickness="1"
                        CornerRadius="8" Canvas.Left="40" Canvas.Top="150">
                    <TextBlock x:Name="txtOrderDate"
                               Foreground="#E0E1F1" FontSize="16"
                               Padding="10" VerticalAlignment="Center"/>
                </Border>

                <!-- Order Time -->
                <TextBlock Text="Order Time"
                           Foreground="#ADACD2" FontSize="13"
                           Canvas.Left="270" Canvas.Top="130"/>
                <Border Width="160" Height="45" Background="#3A2F6F"
                        BorderBrush="#9497CD" BorderThickness="1"
                        CornerRadius="8" Canvas.Left="270" Canvas.Top="150">
                    <TextBlock x:Name="txtOrderTime"
                               Foreground="#E0E1F1" FontSize="16"
                               Padding="10" VerticalAlignment="Center"/>
                </Border>

                <!-- Num Of People -->
                <TextBlock Text="Number of People"
                           Foreground="#ADACD2" FontSize="13"
                           Canvas.Left="460" Canvas.Top="130"/>
                <Border Width="150" Height="45" Background="#3A2F6F"
                        BorderBrush="#9497CD" BorderThickness="1"
                        CornerRadius="8" Canvas.Left="460" Canvas.Top="150">
                    <TextBlock x:Name="txtNumOfPeople"
                               Foreground="#E0E1F1" FontSize="16"
                               Padding="10" VerticalAlignment="Center"/>
                </Border>
                <!-- Meals Section -->
                <TextBlock Text="Ordered Meals"
                           Foreground="#ADACD2" FontSize="13"
                           Canvas.Left="40" Canvas.Top="220"/>
                <TextBlock Text="Total Meals:"
                           Foreground="#ADACD2" FontSize="14"
                           Canvas.Left="685" Canvas.Top="224"></TextBlock>
                <TextBlock Text="{Binding TotalItems}"
                           Foreground="white" FontSize="14"
                           Canvas.Left="769" Canvas.Top="224"></TextBlock>
                <Border Width="758" Height="200"
                        Background="#3A2F6F"
                        BorderBrush="#9497CD" BorderThickness="1"
                        CornerRadius="8"
                        Canvas.Left="40" Canvas.Top="245">

                    <Grid>
                        <!-- Table Reservation Message -->
                        <TextBlock x:Name="txtTableReservation"
                                   Text="Table Reservation — No meals ordered"
                                   Foreground="#ADACD2" FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>

                        <!-- Meals List -->
                        <ListView x:Name="lvMeals"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="#E0E1F1" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,5" Padding="10,8" Width="550"
                                            Background="#1C1448"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <!-- תמונה -->
                                                <ColumnDefinition Width="130"/>
                                                <!-- שם -->
                                                <ColumnDefinition Width="165"/>
                                                <!-- הערות -->
                                                <ColumnDefinition Width="50"/>
                                                <!-- כמות -->
                                                <ColumnDefinition Width="*"/>
                                                <!-- כפתור -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Left: Image + Name -->
                                            <Border Grid.Column="0"
                                                    Height="70"
                                                    Background="#3A2F6F"
                                                    BorderBrush="#9497CD"
                                                    BorderThickness="1"
                                                    Margin="0,0,14,0"
                                                    VerticalAlignment="Center">
                                                <Image Source="{Binding MealPhoto,Converter={StaticResource ImageConverter}}" Stretch="UniformToFill"/>
                                            </Border>

                                            <TextBlock Grid.Column="1" Text="{Binding MealName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#E0E1F1"
                                                       VerticalAlignment="Center"
                                                       Width="100"/>
                                            <TextBlock Grid.Column="2" Text="{Binding MealNotes, StringFormat='&quot;{0}&quot;'}"
                                                       FontSize="12"
                                                       FontStyle="Italic"
                                                       Foreground="Wheat" VerticalAlignment="Center"
                                                       FontFamily="Comic Sans MS"/>

                                            <!-- Right: Quantity + Button -->
                                            <TextBlock Grid.Column="3" Text="{Binding Quantity, StringFormat='x{0}'}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#9497CD"
                                                       VerticalAlignment="Center"
                                                       Width="45"/>

                                            <Button Grid.Column="4" Content="View Meal"
                                                    Width="90" Height="30"
                                                    FontSize="12" FontWeight="SemiBold"
                                                    Foreground="#E0E1F1"
                                                    BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border"
                                                                Background="#4FC3F7"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#29B6F6"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Text="Total Price:"
                                   Foreground="#ADACD2" FontSize="14"
                                   Margin="632,175,0,0"></TextBlock>
                        <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:C}'}"
                                   Foreground="#00FF00" FontSize="14" FontWeight="SemiBold"
                                   Margin="702,175,0,0"></TextBlock>
                    </Grid>
                    
                </Border>

            </Canvas>
        </Border>
        
    </Canvas>
</Window>
