<Window x:Class="PlateUpWpf.Frames.DataEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlateUpWpf.Frames"
        mc:Ignorable="d"
        Height="210" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent">
    <Border BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#6D2FFF" Offset="0"/>
                <GradientStop Color="#FB539B" Offset="0.5"/>
                <GradientStop Color="#836EFB" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2E1065" Offset="0.0"/>
                <GradientStop Color="#0F0720" Offset="0.7"/>
                <GradientStop Color="#03000A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <StackPanel Margin="15">
            <TextBlock x:Name="txtLabel"
                       FontSize="16" 
                       Foreground="#D5CFF5" 
                       FontWeight="Medium" 
                       Margin="0,0,0,10"/>

            <Border Background="White" CornerRadius="8" Height="40">
                <TextBox x:Name="txtName" 
                         FontSize="15" 
                         Padding="8,5" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         VerticalContentAlignment="Center"
                         Foreground="#12194A"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">

                <Button x:Name="btnCancel" 
                        Content="Cancel" 
                        Width="90" Height="35" 
                        Margin="0,0,15,0" 
                        Click="btnCancel_Click"
                        Foreground="GhostWhite" 
                        Background="#15FFFFFF" 
                        BorderThickness="1" 
                        BorderBrush="#30FFFFFF"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnSave" 
                        Content="Save" 
                        Width="90" Height="35" 
                        Click="btnSave_Click"
                        Foreground="White" 
                        Background="#5B21B6" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        FontWeight="SemiBold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
